PORT=3000
JWT_SECRET=CHANGE_THIS_TO_VERY_SECURE_JWT_SECRET_MIN_32_CHARS
JWT_EXPIRES_IN=7200s
REACT_APP_API_URL=https://api.yourdomain.com
