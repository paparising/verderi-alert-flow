{
  "info": {
    "name": "Vederi Alert Flow API",
    "_postman_id": "c9b3d06d-0000-4c00-8000-000000000001",
    "description": "Backend API endpoints with superadmin/user/admin flows.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001" },
    { "key": "superUser", "value": "superadmin" },
    { "key": "superApiKey", "value": "dev-superadmin-key" },
    { "key": "orgId", "value": "11111111-2222-3333-4444-555555555555" },
    { "key": "alertId", "value": "aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee" },
    { "key": "userId", "value": "99999999-8888-7777-6666-555555555555" }
  ],
  "item": [
    {
      "name": "Health",
      "request": { "method": "GET", "url": "{{baseUrl}}/health" }
    },
    {
      "name": "Organizations (superadmin headers)",
      "item": [
        {
          "name": "Create Organization",
          "request": {
            "method": "POST",
            "header": [
              { "key": "x-superuser", "value": "{{superUser}}" },
              { "key": "x-api-key", "value": "{{superApiKey}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Corp\",\n  \"address\": \"123 Main St\",\n  \"contact\": \"owner@example.com\"\n}"
            },
            "url": "{{baseUrl}}/organizations"
          }
        },
        {
          "name": "List Organizations",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-superuser", "value": "{{superUser}}" },
              { "key": "x-api-key", "value": "{{superApiKey}}" }
            ],
            "url": "{{baseUrl}}/organizations"
          }
        },
        {
          "name": "Get Organization by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-superuser", "value": "{{superUser}}" },
              { "key": "x-api-key", "value": "{{superApiKey}}" }
            ],
            "url": "{{baseUrl}}/organizations/{{orgId}}"
          }
        }
      ]
    },
    {
      "name": "Users (superadmin create, admin scoped ops)",
      "item": [
        {
          "name": "Superadmin: Create Admin/User for Org",
          "request": {
            "method": "POST",
            "header": [
              { "key": "x-superuser", "value": "{{superUser}}" },
              { "key": "x-api-key", "value": "{{superApiKey}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"address\": \"123 Main St\",\n  \"email\": \"admin@example.com\",\n  \"phone\": \"555-1234\",\n  \"organizationId\": \"{{orgId}}\",\n  \"password\": \"StrongPass123\",\n  \"role\": \"admin\"\n}"
            },
            "url": "{{baseUrl}}/superadmin/users/admin"
          }
        },
        {
          "name": "Auth: Login (email/password)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"StrongPass123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Admin: Create Org User (uses orgId from JWT)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwtAdmin}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Org User\",\n  \"address\": \"123 Main St\",\n  \"email\": \"user1@example.com\",\n  \"phone\": \"555-9999\",\n  \"organizationId\": \"{{orgId}}\"\n}"
            },
            "url": "{{baseUrl}}/users"
          }
        },
        {
          "name": "Admin: List Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwtAdmin}}" }],
            "url": "{{baseUrl}}/users"
          }
        },
        {
          "name": "Admin: Get User by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwtAdmin}}" }],
            "url": "{{baseUrl}}/users/{{userId}}"
          }
        }
      ]
    },
    {
      "name": "Alerts (org-scoped, admin/user)",
      "item": [
        {
          "name": "Create Alert",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwtAdmin}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"CPU High\",\n  \"description\": \"CPU usage > 90%\",\n  \"severity\": \"high\",\n  \"status\": \"open\"\n}"
            },
            "url": "{{baseUrl}}/alerts"
          }
        },
        {
          "name": "List Alerts",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwtUser}}" }],
            "url": {
              "raw": "{{baseUrl}}/alerts?status=open",
              "host": ["{{baseUrl}}"],
              "path": ["alerts"],
              "query": [{ "key": "status", "value": "open" }]
            }
          }
        },
        {
          "name": "Update Alert Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwtUser}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"resolved\"\n}"
            },
            "url": "{{baseUrl}}/alerts/{{alertId}}/status"
          }
        },
        {
          "name": "List Alert Events",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwtUser}}" }],
            "url": "{{baseUrl}}/alerts/{{alertId}}/events"
          }
        }
      ]
    }
  ]
}
