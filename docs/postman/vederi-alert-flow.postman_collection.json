{
  "info": {
    "name": "Vederi Alert Flow API",
    "_postman_id": "c9b3d06d-0000-4c00-8000-000000000001",
    "description": "API collection for superadmin org setup, admin user management, auth, alerts, and alert events. Includes error handling scenarios for circuit breaker, timeout, and network error testing.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001" },
    { "key": "superUser", "value": "superadmin" },
    { "key": "superApiKey", "value": "dev-superadmin-key" },
    { "key": "orgId", "value": "11111111-2222-3333-4444-555555555555" },
    { "key": "alertId", "value": "aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee" },
    { "key": "userId", "value": "99999999-8888-7777-6666-555555555555" },
    { "key": "jwtAdmin", "value": "" },
    { "key": "jwtUser", "value": "" },
    { "key": "jwtSuperadmin", "value": "", "description": "JWT token for superadmin user (role: superadmin)" }
  ],
  "item": [
    {
      "name": "Health",
      "request": { "method": "GET", "url": "{{baseUrl}}/health" },
      "response": []
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (email/password)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"StrongPass123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "response": []
        },
        {
          "name": "Login - Invalid Credentials (401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"WrongPassword\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Organizations (superadmin headers)",
      "item": [
        {
          "name": "Create Organization",
          "request": {
            "method": "POST",
            "header": [
              { "key": "x-superuser", "value": "{{superUser}}" },
              { "key": "x-api-key", "value": "{{superApiKey}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Corp\",\n  \"address\": \"123 Main St\",\n  \"contact\": \"owner@example.com\"\n}"
            },
            "url": "{{baseUrl}}/organizations"
          }
        },
        {
          "name": "List Organizations",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-superuser", "value": "{{superUser}}" },
              { "key": "x-api-key", "value": "{{superApiKey}}" }
            ],
            "url": "{{baseUrl}}/organizations"
          }
        },
        {
          "name": "Get Organization by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-superuser", "value": "{{superUser}}" },
              { "key": "x-api-key", "value": "{{superApiKey}}" }
            ],
            "url": "{{baseUrl}}/organizations/{{orgId}}"
          }
        }
      ]
    },
    {
      "name": "Users (admin JWT)",
      "item": [
        {
          "name": "Create Org User (password required)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwtAdmin}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Org User\",\n  \"address\": \"123 Main St\",\n  \"email\": \"user1@example.com\",\n  \"phone\": \"555-9999\",\n  \"password\": \"StrongPass123\",\n  \"role\": \"admin\"\n}"
            },
            "url": "{{baseUrl}}/users"
          }
        },
        {
          "name": "Create User for Different Org (superadmin)",
          "description": "Superadmin can create users for any organization by specifying organizationId in the request body",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwtSuperadmin}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Cross-Org User\",\n  \"address\": \"456 Oak Ave\",\n  \"email\": \"crossorg@example.com\",\n  \"phone\": \"555-1234\",\n  \"password\": \"StrongPass123\",\n  \"role\": \"admin\",\n  \"organizationId\": \"{{orgId}}\"\n}"
            },
            "url": "{{baseUrl}}/users"
          }
        },
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwtAdmin}}" }],
            "url": "{{baseUrl}}/users"
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwtAdmin}}" }],
            "url": "{{baseUrl}}/users/{{userId}}"
          }
        },
        {
          "name": "Update User (password optional)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwtAdmin}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\",\n  \"phone\": \"555-0000\",\n  \"password\": \"NewStrongPass123\"\n}"
            },
            "url": "{{baseUrl}}/users/{{userId}}"
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwtAdmin}}" }],
            "url": "{{baseUrl}}/users/{{userId}}"
          }
        }
      ]
    },
    {
      "name": "Alerts (org-scoped)",
      "item": [
        {
          "name": "Create Alert",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwtAdmin}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"alertContext\": \"CPU usage > 90%\",\n  \"status\": \"New\"\n}"
            },
            "url": "{{baseUrl}}/alerts"
          },
          "response": []
        },
        {
          "name": "Create Alert - Missing Context (400)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwtAdmin}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"New\"\n}"
            },
            "url": "{{baseUrl}}/alerts"
          },
          "response": []
        },
        {
          "name": "List Alerts",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwtUser}}" }],
            "url": {
              "raw": "{{baseUrl}}/alerts?status=New&mine=false",
              "host": ["{{baseUrl}}"],
              "path": ["alerts"],
              "query": [
                { "key": "status", "value": "New" },
                { "key": "mine", "value": "false" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "List Alerts - Unauthorized (401)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer invalid-token" }],
            "url": "{{baseUrl}}/alerts"
          },
          "response": []
        },
        {
          "name": "Update Alert Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwtUser}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Acknowledged\"\n}"
            },
            "url": "{{baseUrl}}/alerts/{{alertId}}/status"
          },
          "response": []
        },
        {
          "name": "Update Alert (context/status)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwtUser}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"alertContext\": \"Adjusted context\",\n  \"status\": \"Resolved\"\n}"
            },
            "url": "{{baseUrl}}/alerts/{{alertId}}"
          },
          "response": []
        },
        {
          "name": "Update Alert - Not Found (404)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwtUser}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Resolved\"\n}"
            },
            "url": "{{baseUrl}}/alerts/00000000-0000-0000-0000-000000000000"
          },
          "response": []
        },
        {
          "name": "Delete Alert",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwtUser}}" }],
            "url": "{{baseUrl}}/alerts/{{alertId}}"
          },
          "response": []
        },
        {
          "name": "List Alert Events",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwtUser}}" }],
            "url": "{{baseUrl}}/alerts/{{alertId}}/events"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Error Handling Tests",
      "description": "Tests for circuit breaker, retry, and error response patterns",
      "item": [
        {
          "name": "Test Circuit Breaker Recovery",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwtAdmin}}" }],
            "url": "{{baseUrl}}/alerts",
            "description": "After multiple failures (5+), backend opens circuit breaker. Subsequent requests return 503 with 'Service temporarily unavailable - circuit breaker is OPEN'. Circuit recovers after 60 seconds."
          },
          "response": []
        },
        {
          "name": "Test 400 Bad Request",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwtAdmin}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"invalidField\": \"test\"\n}"
            },
            "url": "{{baseUrl}}/alerts",
            "description": "Sends invalid payload to test 400 error response handling."
          },
          "response": []
        },
        {
          "name": "Test 401 Unauthorized",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/alerts",
            "description": "Request without Authorization header triggers 401 Unauthorized."
          },
          "response": []
        },
        {
          "name": "Test 403 Forbidden",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwtUser}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"Test123\"\n}"
            },
            "url": "{{baseUrl}}/users",
            "description": "Non-admin user attempting admin-only operation triggers 403 Forbidden."
          },
          "response": []
        }
      ]
    }
  ]
}
