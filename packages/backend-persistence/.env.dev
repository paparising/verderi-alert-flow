# Backend Persistence Service - Development Environment

# Environment
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5438
DB_USER=postgres
DB_PASS=password
DB_NAME=vederi

# Kafka
KAFKA_BROKER=localhost:9092

# Consumer Configuration
KAFKA_CONSUMER_GROUP=alert-events-persistence-group
KAFKA_CLIENT_ID=vederi-alert-flow-persistence
KAFKA_TOPIC=alert-events

# Logging
LOG_LEVEL=debug
