# Backend API Service - Development Environment

# Server
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5438
DB_USER=postgres
DB_PASS=password
DB_NAME=vederi

# Kafka
KAFKA_BROKER=localhost:9092

# Alert Event Processing
# Polling interval in milliseconds for publishing unpublished alert events to Kafka
# Default: 1000ms (1 second)
ALERT_EVENT_POLLING_INTERVAL_MS=1000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Rate Limiting
RATE_LIMIT_MAX=10000
RATE_LIMIT_WINDOW_MS=1000

# Auth
JWT_SECRET=dev-change-me
JWT_EXPIRES_IN=1h
JWT_ISSUER=vederi-alert-flow
JWT_AUDIENCE=vederi-alert-flow-clients

# Logging
LOG_LEVEL=debug

# Superadmin
SUPERADMIN_USER=superadmin
SUPERADMIN_API_KEY=dev-superadmin-key
