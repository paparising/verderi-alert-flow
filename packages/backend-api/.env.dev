# Backend API Service - Development Environment

# Server
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5438
DB_USER=postgres
DB_PASS=password
DB_NAME=vederi

# Kafka
KAFKA_BROKER=localhost:9092

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Rate Limiting
RATE_LIMIT_MAX=10000
RATE_LIMIT_WINDOW_MS=1000

# Logging
LOG_LEVEL=debug
