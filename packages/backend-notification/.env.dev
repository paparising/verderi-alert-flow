# Backend Notification Service - Development Environment

# Environment
NODE_ENV=development

# Kafka
KAFKA_BROKER=localhost:9092

# Consumer Configuration
KAFKA_CONSUMER_GROUP=alert-events-notification-group
KAFKA_CLIENT_ID=vederi-alert-flow-notification
KAFKA_TOPIC=alert-events

# WebSocket
WEBSOCKET_CORS_ORIGIN=*

# Logging
LOG_LEVEL=debug
