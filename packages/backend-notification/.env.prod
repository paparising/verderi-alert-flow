# Backend Notification Service - Production Environment

# Environment
NODE_ENV=production

# Kafka
# Replace with your production Kafka broker
KAFKA_BROKER=your-production-kafka:9092

# Consumer Configuration
KAFKA_CONSUMER_GROUP=alert-events-notification-group
KAFKA_CLIENT_ID=vederi-alert-flow-notification
KAFKA_TOPIC=alert-events

# WebSocket
# Replace with your production frontend URL
WEBSOCKET_CORS_ORIGIN=https://your-production-domain.com

# Logging
LOG_LEVEL=info
