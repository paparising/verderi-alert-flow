# Frontend - Production Environment

# API URL
# Replace with your production API URL
REACT_APP_API_URL=https://api.your-production-domain.com

# WebSocket URL (backend-notification service)
# Replace with your production notification service URL
REACT_APP_WS_URL=https://ws.your-production-domain.com

# Environment
REACT_APP_ENV=production

# Feature Flags
REACT_APP_ENABLE_DEBUG=false
