# Root Development Environment
# Used by Docker Compose for development

# Database
DB_HOST=db
DB_PORT=5438
DB_USER=postgres
DB_PASS=password
DB_NAME=vederi

# Kafka
KAFKA_BROKER=kafka:9092

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Rate Limiting
RATE_LIMIT_MAX=10000
RATE_LIMIT_WINDOW_MS=1000

# API Service
PORT=3003

# Environment
NODE_ENV=development
